<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.webhookbridge.extension" extension-version="1.0.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name"/>
    <description>Send selected mark data to any webhook endpoint</description>
    <author name="Webhook Bridge" email="" organization="" website=""/>
    <min-api-version>1.7</min-api-version>
    <source-location>
      <url>https://git.soma.salesforce.com/pages/ben-hart/tableau-webook-bridge/index.html</url>
    </source-location>
    <icon>iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==</icon>
  </dashboard-extension>
  <resources>
    <resource id="name">
      <string locale="en_US">Webhook Bridge</string>
    </resource>
  </resources>
</manifest>
